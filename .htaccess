<IfModule mod_rewrite.c>
    RewriteEngine on

    # define RewriteBase and store it
    RewriteCond %{REQUEST_URI}::$1 ^(.*?/)(.*)::\2$
    RewriteRule ^(.*)$ - [E=BASE:%1]

    # Redirect any explicit /public/ URL back to the clean one. Must be an
    # absolute path (BASE prefix) so the browser doesn't append it to the
    # current URL, which would produce /XGProyect/public/admin/admin/server.
    RewriteCond %{THE_REQUEST} /public/([^\s?]*) [NC]
    RewriteRule ^ %{ENV:BASE}%1 [L,NE,R=302]

    # Then rewrite the clean URL internally to /public/ so PHP serves index.php.
    RewriteRule ^((?!public/).*)$ %{ENV:BASE}public/$1 [L,NC]
</IfModule>