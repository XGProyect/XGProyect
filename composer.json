{
    "name": "xgproyect/xgproyect",
    "description": "XGP Open-source OGame Clon",
    "keywords": [
        "ogame",
        "clon"
    ],
    "type": "project",
    "homepage": "https://xgproyect.org",
    "support": {
        "source": "https://github.com/XGProyect/XGProyect",
        "issues": "https://github.com/XGProyect/XGProyect/issues"
    },
    "authors": [
        {
            "name": "Lucas Kovács",
            "homepage": "https://github.com/LucasKovacs",
            "role": "Lead"
        }
    ],
    "license": "GPL-3.0-only",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "spatie/laravel-backup": "^9.4"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "fakerphp/faker": "^1.9.1",
        "friendsofphp/php-cs-fixer": "^3.16",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Xgp\\App\\": "legacy/app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "phpunit": [
            "vendor/bin/phpunit"
        ],
        "phpcompatinfo": [
            "vendor/bin/phpcompatinfo --progress analyser:run ./legacy/"
        ],
        "phpstan": [
            "vendor/bin/phpstan analyse app legacy tests"
        ],
        "phpstan-baseline": [
            "vendor/bin/phpstan analyse --level 9 --configuration=phpstan.neon --generate-baseline=phpstan-baseline.neon app/ legacy/ tests/ --memory-limit 1024M"
        ],
        "phpmd-baseline": [
            "vendor/bin/phpmd --generate-baseline app/ legacy/ github phpmd.xml"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
